{
  "usesTypeScript": true,
  "testLibrary": "None",
  "component": {
    "default": {
      "path": "src/components",
      "withStyle": true,
      "customTemplates": {
        "component": "templates/component/TemplateName.tsx",
        "style": "templates/component/TemplateName.module.css"
      },
      "withTest": false,
      "withStory": false,
      "withLazy": false
    },
    "context": {
      "path": "src/contexts",
      "withLazy": false,
      "withStory": false,
      "withStyle": false,
      "withTest": false,
      "flat": true,
      "customTemplates": {
        "component": "templates/context/TemplateName.tsx"
      } 
    }
  },
  "usesCssModule": true,
  "cssPreprocessor": "css",
  "usesStyledComponents": false
}