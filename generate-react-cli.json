{
  "usesTypeScript": true,
  "testLibrary": "None",
  "component": {
    "default": {
      "path": "src/components",
      "withStyle": true,
      "customTemplates": {
        "component": "templates/component/TemplateName.tsx",
        "style": "templates/component/TemplateName.module.css"
      },
      "withTest": false,
      "withStory": false,
      "withLazy": false
    },
    "context": {
      "path": "src/contexts",
      "withLazy": false,
      "withStory": false,
      "withStyle": false,
      "withTest": false,
      "withIndex": true,
      "withContext": true,
      "withHelper": true,
      "customTemplates": {
        "component": "templates/context/provider.tsx",
        "index": "templates/context/index.ts",
        "context": "templates/context/context.ts",
        "helper": "templates/context/helper.ts"
      } 
    }
  },
  "usesCssModule": true,
  "cssPreprocessor": "css",
  "usesStyledComponents": false
}